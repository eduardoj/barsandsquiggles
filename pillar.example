# barsandsquiggles pillar example
#
# All top-level keys are optional. Omitting a key (or setting enabled: false)
# disables that component and triggers cleanup of its packages/config/service.

# ---------------------------------------------------------------------------
# Loki
# ---------------------------------------------------------------------------
loki:
  tls:
    {%- set ca_path = "/usr/share/pki/trust/anchors/step-ca-at-home.crt.pem" %}
    ca_path: {{ ca_path }}
    tls_min_version: VersionTLS13
    tls_cipher_suites: TLS_CHACHA20_POLY1305_SHA256

    server:
      cert_file: /etc/step/certs/generic.host.full.pem
      key_file:  /etc/step/certs/generic.host.full.pem
      client_auth_type: RequireAndVerifyClientCert
    client:
      tls_cert_path: /etc/step/certs/generic.user.full.pem
      tls_key_path:  /etc/step/certs/generic.user.full.pem
  enabled: true
  config:
    auth_enabled: false
    server:
      http_listen_port: 3100
    common:
      instance_addr: 127.0.0.1
      path_prefix: /var/lib/loki
      storage:
        filesystem:
          chunks_directory: /var/lib/loki/chunks
          rules_directory: /var/lib/loki/rules
      replication_factor: 1
      ring:
        kvstore:
          store: inmemory
    schema_config:
      configs:
        - from: "2020-10-24"
          store: tsdb
          object_store: filesystem
          schema: v13
          index:
            prefix: index_
            period: 24h

# ---------------------------------------------------------------------------
# Tempo
# ---------------------------------------------------------------------------
tempo:
  enabled: true
  config:
    server:
      http_listen_port: 3200
    distributor:
      receivers:
        otlp:
          protocols:
            http: {}
            grpc: {}
    storage:
      trace:
        backend: local
        local:
          path: /var/lib/tempo/traces
        wal:
          path: /var/lib/tempo/wal

# ---------------------------------------------------------------------------
# Mimir — multi-instance example
# ---------------------------------------------------------------------------
mimir:
  enabled: true
  instances:
    default:
      server:
        http_listen_port: 9009
      blocks_storage:
        backend: filesystem
        filesystem:
          dir: /var/lib/mimir/blocks
      compactor:
        data_dir: /var/lib/mimir/compactor
      ingester:
        ring:
          replication_factor: 1

# ---------------------------------------------------------------------------
# Grafana
# ---------------------------------------------------------------------------
grafana:
  enabled: true

  # Plugins to install via grafana-cli (idempotent)
  plugins:
    - grafana-clock-panel
    - grafana-piechart-panel

  # Written to /etc/grafana/grafana.ini in INI format
  config:
    server:
      http_port: 3000
    security:
      admin_user: admin
    auth.anonymous:
      enabled: false

  provisioning:
    # Each key becomes /etc/grafana/provisioning/datasources/{name}.yaml
    datasources:
      default:
        apiVersion: 1
        datasources:
          - name: Prometheus
            type: prometheus
            uid: prometheus
            access: proxy
            orgId: 1
            url: http://localhost:9090/
            version: 1
            editable: true
            isDefault: true
          - name: Loki
            type: loki
            uid: loki
            access: proxy
            orgId: 1
            url: http://localhost:3100/
            version: 1
            editable: true
          - name: Tempo
            type: tempo
            uid: tempo
            access: proxy
            orgId: 1
            url: http://localhost:3200/
            version: 1
            editable: true

    # Each key becomes /etc/grafana/provisioning/dashboards/{name}.yaml
    # Files are fetched from the Salt fileserver and placed under
    # /var/lib/grafana/dashboards/
    dashboards:
      default:
        config:
          - name: dashboards
            org_id: 1
            folder: ''
            type: file
            disableDeletion: false
            allowUiUpdates: true
            options:
              folder: /var/lib/grafana/dashboards
        files:
          example.json: salt://grafana/dashboards/example.json

# ---------------------------------------------------------------------------
# Vector
# ---------------------------------------------------------------------------
#
# some available includes
#
#   - barsandsquiggles.vector.base-config
#   - barsandsquiggles.vector.local_journal
#   - barsandsquiggles.vector.auditd
#   - barsandsquiggles.vector.use-step-ca-generic-certificates
#
vector:
  enabled: true
  enable_journal: true           # adds vector-systemd package
  enable_remote_journal: false   # adds vector-systemd-journal-remote package
  use_hardened_service: false    # use hardened-vector.service instead of vector.service
  additional_groups:
    - nginx
    - valkey
  #
  # if you prefer the configuration in another format than yaml you can also set json or toml.
  # default is yaml
  #
  # config_format: yaml
  #
  # optionally allow setting enviroment variables
  # see vector's documentation
  #
  # you do not have to set VECTOR_CONFIG_{{ config_format }}=path as the code will do this automatically.
  #
  # environment:
  #   - VECTOR_THREADS={{ grains.num_cpus / 2 }}
  config:
    sources:
      journald:
        type: journald
    sinks:
      loki:
        type: loki
        inputs:
          - journald
        endpoint: http://localhost:3100
        encoding:
          codec: json
        labels:
          host: "{{ host }}"
    api:
      enabled: true
      address: "127.0.0.1:8686"
